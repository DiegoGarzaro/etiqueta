# Copy to .env before running docker compose.

# Port published on your server. The app will be at http://your-server:8070
APP_PORT=8070

# PostgreSQL credentials. CHANGE THE PASSWORD before exposing the server.
POSTGRES_USER=inventory
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=inventory

# SLP650 thermal print server (REST agent on the Raspberry Pi, Tailscale IP).
# The key is server-side only — it must never reach browser code.
SLP650_BASE_URL=http://100.87.166.24:8787
SLP650_API_KEY=

# Access PIN (4-8 digits). Optional seed for first boot only: once a PIN is
# stored (hashed) in the database, it takes precedence and can be changed in
# Ajustes. Leave empty to start the app open and set the PIN in the UI.
INV_APP_PIN=

# Canonical address users open the app at (goes inside printed QR codes).
# When set, every label points here no matter where it was printed from.
# Give the server a static IP / DHCP reservation so labels never break.
INV_PUBLIC_BASE_URL=http://10.0.0.228:8070
